# AI API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
MONGODB_URI=mongodb://fnovel:fnovel@localhost:27017/fnovel?authSource=admin
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CRAWL_TOPIC=fnovel.crawl.events
KAFKA_OCR_TOPIC=fnovel.ocr.events

# Backend API
FNOVEL_BACKEND_URL=http://localhost:8080

# Crawler settings
CRAWLER_USER_AGENT=FNovelBot/1.0
CRAWLER_REQUEST_DELAY=2
